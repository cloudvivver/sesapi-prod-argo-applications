# Copie para app-secrets.yaml, preencha e aplique manualmente.
# NÃO commitar app-secrets.yaml (coberto pelo .gitignore do repositório k8s).
#
# kubectl apply -f app-secrets.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: edne-endereco
type: Opaque
stringData:
  CEP_API_KEY: "<definir-no-cluster>"
